{
  "$schema": "./golden-tests.schema.json",
  "version": "2.0",
  "mcp_name": "Indonesian Law MCP",
  "description": "Golden contract tests for the Indonesian Law MCP covering 1,924 Undang-Undang (Laws) with census-first full corpus ingestion",
  "tests": [
    {
      "id": "id-001",
      "category": "article_retrieval",
      "description": "Retrieve Article 1 of the PDP Law (UU No. 27/2022) -- definitions including personal data (data pribadi)",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 27 Tahun 2022",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["data pribadi", "Pengendali Data Pribadi"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "id-002",
      "category": "article_retrieval",
      "description": "Retrieve Article 1 of the ITE Law (UU No. 11/2008) -- definitions of electronic information and transactions",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 11 Tahun 2008",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["informasi elektronik", "electronic information", "transaksi elektronik"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "id-003",
      "category": "article_retrieval",
      "description": "Retrieve Article 1 of the Company Law (UU No. 40/2007) -- definitions of Perseroan Terbatas",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 40 Tahun 2007",
        "article": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["perseroan", "company", "badan hukum"],
        "fields_present": ["text", "article_number"],
        "text_not_empty": true
      }
    },
    {
      "id": "id-004",
      "category": "article_retrieval",
      "description": "Retrieve Article 26 of the ITE Law -- personal data protection provision",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 11 Tahun 2008",
        "article": "26"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["data pribadi", "persetujuan"],
        "fields_present": ["text"],
        "text_not_empty": true
      }
    },
    {
      "id": "id-005",
      "category": "search",
      "description": "Full-text search for 'data pribadi' returns PDP Law provisions",
      "tool": "search_legislation",
      "input": {
        "query": "data pribadi"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["data pribadi", "Pelindungan Data Pribadi"]
      }
    },
    {
      "id": "id-006",
      "category": "search",
      "description": "Full-text search for 'transaksi elektronik' returns ITE Law provisions",
      "tool": "search_legislation",
      "input": {
        "query": "transaksi elektronik"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["Informasi dan Transaksi Elektronik", "transaksi elektronik", "ITE"]
      }
    },
    {
      "id": "id-007",
      "category": "search",
      "description": "Full-text search for 'perlindungan konsumen' returns Consumer Protection Law",
      "tool": "search_legislation",
      "input": {
        "query": "perlindungan konsumen"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["konsumen", "perlindungan"]
      }
    },
    {
      "id": "id-008",
      "category": "citation_roundtrip",
      "description": "Citation for PDP Law Article 15 includes peraturan URL pattern",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 27 Tahun 2022",
        "article": "15"
      },
      "assertions": {
        "result_not_empty": true,
        "text_not_empty": true
      }
    },
    {
      "id": "id-009",
      "category": "listing",
      "description": "List all laws returns the full corpus count",
      "tool": "list_documents",
      "input": {},
      "assertions": {
        "result_not_empty": true,
        "min_results": 1900
      }
    },
    {
      "id": "id-010",
      "category": "search",
      "description": "Search for 'telekomunikasi' returns Telecommunications Law provisions",
      "tool": "search_legislation",
      "input": {
        "query": "telekomunikasi"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["telekomunikasi", "Telekomunikasi"]
      }
    },
    {
      "id": "id-011",
      "category": "negative_test",
      "description": "Non-existent Indonesian law returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 999 Tahun 2099 Fictional Space Law",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "id-012",
      "category": "negative_test",
      "description": "Malformed article number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "UU No. 27 Tahun 2022",
        "article": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
